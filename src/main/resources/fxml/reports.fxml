<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox spacing="25"
      alignment="CENTER"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.stockpilot.controller.ReportsController">


    <Label text="Sales Reports"
           style="-fx-font-size:28px;
                  -fx-font-weight:bold;"/>



    <HBox spacing="30"
          alignment="CENTER">


        <VBox spacing="10"
              alignment="CENTER"
              style="-fx-background-color:#e2e8f0;
                     -fx-padding:20;
                     -fx-background-radius:10;">


            <Label text="Today's Sales"/>

            <Label fx:id="todaySalesLabel"
                   text="0"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;"/>


        </VBox>



        <VBox spacing="10"
              alignment="CENTER"
              style="-fx-background-color:#e2e8f0;
                     -fx-padding:20;
                     -fx-background-radius:10;">


            <Label text="Best Selling Recipe"/>


            <Label fx:id="bestSellerLabel"
                   text="None"
                   style="-fx-font-size:22px;
                          -fx-font-weight:bold;"/>


        </VBox>


    </HBox>



    <Button text="Back"
            onAction="#goBack"/>


</VBox>