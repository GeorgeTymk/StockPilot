<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.stockpilot.controller.ReportsController"
      spacing="0">


    <!-- SIDEBAR -->

    <fx:include source="sidebar.fxml"/>




    <!-- PAGE CONTENT -->

    <BorderPane HBox.hgrow="ALWAYS"
                styleClass="page-container">



        <!-- HEADER -->

        <top>


            <HBox alignment="CENTER_LEFT"
                  styleClass="page-header">


                <padding>

                    <Insets top="20"
                            right="25"
                            bottom="20"
                            left="25"/>

                </padding>



                <VBox spacing="5">


                    <Label text="Sales Reports"
                           styleClass="page-title"/>


                    <Label text="Business performance overview"
                           styleClass="subtitle"/>


                </VBox>



            </HBox>


        </top>






        <!-- CONTENT -->

        <center>


            <VBox spacing="25">


                <padding>

                    <Insets top="30"
                            right="30"
                            bottom="30"
                            left="30"/>

                </padding>






                <!-- REPORT CARDS -->

                <HBox spacing="30">



                    <VBox spacing="10"
                          alignment="CENTER"
                          styleClass="stat-card">


                        <Label text="Today's Sales"/>


                        <Label fx:id="todaySalesLabel"
                               text="0"
                               styleClass="stat-value"/>


                    </VBox>







                    <VBox spacing="10"
                          alignment="CENTER"
                          styleClass="stat-card">


                        <Label text="Best Selling Recipe"/>


                        <Label fx:id="bestSellerLabel"
                               text="None"
                               styleClass="stat-value"/>


                    </VBox>




                </HBox>








                <!-- BUTTONS -->

                <HBox spacing="15">


                    <Button text="Back"
                            onAction="#goBack"
                            styleClass="secondary-button"/>


                </HBox>





            </VBox>



        </center>




    </BorderPane>



</HBox>