<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.stockpilot.controller.IngredientController"
      spacing="20"
      styleClass="floating-dashboard">


    <padding>

        <Insets top="30"
                right="35"
                bottom="30"
                left="35"/>

    </padding>



    <VBox spacing="5">


        <Label text="Ingredient Management"
               styleClass="page-title"/>


        <Label text="Manage restaurant ingredients"
               styleClass="page-subtitle"/>


    </VBox>





    <TableView fx:id="ingredientTable"
               VBox.vgrow="ALWAYS"
               styleClass="inventory-table">


        <columns>


            <TableColumn fx:id="idColumn"
                         text="ID"
                         prefWidth="80"/>


            <TableColumn fx:id="nameColumn"
                         text="Ingredient"
                         prefWidth="200"/>


            <TableColumn fx:id="quantityColumn"
                         text="Quantity"
                         prefWidth="120"/>


            <TableColumn fx:id="unitColumn"
                         text="Unit"
                         prefWidth="120"/>


            <TableColumn fx:id="minimumColumn"
                         text="Minimum Stock"
                         prefWidth="150"/>


            <TableColumn fx:id="statusColumn"
                         text="Status"
                         prefWidth="120"/>


        </columns>


    </TableView>





    <HBox spacing="15">


        <Button text="Add Ingredient"
                styleClass="primary-button"
                onAction="#addIngredient"/>



        <Button text="Restock"
                styleClass="primary-button"
                onAction="#restockIngredient"/>



        <Button text="Inventory History"
                styleClass="secondary-button"
                onAction="#openHistory"/>



        <Button text="Back"
                styleClass="secondary-button"
                onAction="#goBack"/>


    </HBox>


</VBox>