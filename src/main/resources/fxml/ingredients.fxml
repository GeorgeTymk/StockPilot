<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.stockpilot.controller.IngredientController"
      spacing="0">


    <!-- SIDEBAR -->

    <fx:include source="sidebar.fxml"/>



    <!-- CONTENT -->

    <BorderPane HBox.hgrow="ALWAYS"
                styleClass="page-container">



        <!-- HEADER -->

        <top>

            <HBox alignment="CENTER_LEFT"
                  styleClass="page-header">

                <padding>

                    <Insets top="20"
                            right="25"
                            bottom="20"
                            left="25"/>

                </padding>


                <Label text="Ingredient Management"
                       styleClass="page-title"/>

            </HBox>

        </top>




        <!-- TABLE AREA -->

        <center>

            <VBox spacing="20"
                  fillWidth="true">


                <padding>

                    <Insets top="25"
                            right="25"
                            bottom="25"
                            left="25"/>

                </padding>



                <TableView fx:id="ingredientTable"
           prefHeight="500">


                    <columns>


                        <TableColumn fx:id="idColumn"
                                     text="ID"
                                     prefWidth="80"/>


                        <TableColumn fx:id="nameColumn"
                                     text="Ingredient"
                                     prefWidth="200"/>


                        <TableColumn fx:id="quantityColumn"
                                     text="Quantity"
                                     prefWidth="120"/>


                        <TableColumn fx:id="unitColumn"
                                     text="Unit"
                                     prefWidth="120"/>


                        <TableColumn fx:id="minimumColumn"
                                     text="Minimum Stock"
                                     prefWidth="150"/>


                        <TableColumn fx:id="statusColumn"
                                     text="Status"
                                     prefWidth="120"/>


                    </columns>


                </TableView>



                <!-- BUTTONS -->

<HBox spacing="15"
      alignment="CENTER_LEFT"
      styleClass="button-bar">


    <Button text="Add Ingredient"
            styleClass="primary-button"
            onAction="#addIngredient"/>


    <Button text="Restock"
            styleClass="primary-button"
            onAction="#restockIngredient"/>


    <Button text="Inventory History"
            styleClass="secondary-button"
            onAction="#openHistory"/>


    <Button text="Back"
            styleClass="secondary-button"
            onAction="#goBack"/>


</HBox>


            </VBox>


        </center>



    </BorderPane>


</HBox>