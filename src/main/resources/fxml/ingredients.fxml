<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.stockpilot.controller.IngredientController">


    <top>

        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:#1e293b;">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>


            <Label text="Ingredient Management"
                   style="-fx-text-fill:white;
                          -fx-font-size:22px;
                          -fx-font-weight:bold;"/>

        </HBox>

    </top>



    <center>


        <VBox spacing="20">


            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>



            <TableView fx:id="ingredientTable">


                <columns>


                    <TableColumn fx:id="idColumn"
                                 text="ID"/>


                    <TableColumn fx:id="nameColumn"
                                 text="Ingredient"/>


                    <TableColumn fx:id="quantityColumn"
                                 text="Quantity"/>


                    <TableColumn fx:id="unitColumn"
                                 text="Unit"/>

                    <TableColumn fx:id="minimumColumn"
             text="Minimum Stock"/>

             <TableColumn fx:id="statusColumn"
             text="Status"/>


                </columns>


            </TableView>



            <Button text="Add Ingredient"
        onAction="#addIngredient"/>

<Button text="Restock"
        onAction="#restockIngredient"/>

<Button text="Back"
        onAction="#goBack"/>


        </VBox>


    </center>


</BorderPane>