<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>


<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>


<StackPane fx:id="root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.stockpilot.controller.LoginController"
           stylesheets="@../css/login.css">


    <!-- BACKGROUND -->
    <AnchorPane styleClass="login-background">


        <!-- Decorative circles -->

        <Circle radius="180"
                styleClass="circle-one"
                AnchorPane.rightAnchor="-80"
                AnchorPane.topAnchor="-70"/>


        <Circle radius="120"
                styleClass="circle-two"
                AnchorPane.leftAnchor="-50"
                AnchorPane.bottomAnchor="80"/>


        <Circle radius="45"
                styleClass="circle-three"
                AnchorPane.rightAnchor="220"
                AnchorPane.bottomAnchor="120"/>



        <!-- MAIN CARD -->

        <HBox styleClass="login-card"
              AnchorPane.leftAnchor="80"
              AnchorPane.rightAnchor="80"
              AnchorPane.topAnchor="70"
              AnchorPane.bottomAnchor="70">


            <!-- LEFT GREEN PANEL -->

            <VBox styleClass="login-left-panel"
                  prefWidth="420"
                  alignment="CENTER">


                <VBox alignment="CENTER"
                      spacing="15"
                      styleClass="brand-area">


                    <Label text="StockPilot"
                           styleClass="brand-title"/>


                    <Label text="Restaurant Inventory Management"
                           styleClass="brand-subtitle"/>


                </VBox>



                <!-- Logo placeholder -->

                <StackPane styleClass="logo-circle">

    <ImageView fitWidth="85"
               fitHeight="85"
               preserveRatio="true">

        <image>

            <Image url="@../images/stockpilot-logo.png"/>

        </image>

    </ImageView>

</StackPane>



                <VBox alignment="CENTER"
                      spacing="8"
                      styleClass="welcome-area">


                    <Label text="Smart inventory."
                           styleClass="welcome-title"/>


                    <Label text="Simplified control."
                           styleClass="welcome-title"/>


                    <Label text="Manage stock, recipes and sales with ease."
                           wrapText="true"
                           styleClass="welcome-description"/>


                </VBox>



                <!-- FOOTER -->

                <VBox alignment="CENTER"
                      spacing="5"
                      VBox.vgrow="ALWAYS"
                      styleClass="footer-area">


                    <Label text="© 2026 StockPilot"
                           styleClass="footer-main"/>


                    <Label text="Designed by George Tymk Phoenix Systems"
                           styleClass="footer-sub"/>


                </VBox>



            </VBox>





            <!-- RIGHT LOGIN PANEL -->

            <VBox styleClass="login-right-panel"
                  alignment="CENTER"
                  spacing="25">


                <VBox alignment="CENTER"
                      spacing="8">


                    <Label text="Welcome Back"
                           styleClass="login-title"/>


                    <Label text="Login to continue to StockPilot"
                           styleClass="login-description"/>


                </VBox>





                <!-- USERNAME -->

                <VBox spacing="8"
                      styleClass="input-container">


                    <Label text="Username"
                           styleClass="input-label"/>


                    <TextField fx:id="usernameField"
                               promptText="Enter your username"
                               styleClass="login-input"/>


                </VBox>





                <!-- PASSWORD -->

                <VBox spacing="8"
                      styleClass="input-container">


                    <Label text="Password"
                           styleClass="input-label"/>


                    <PasswordField fx:id="passwordField"
                                   promptText="Enter your password"
                                   onAction="#login"
                                   styleClass="login-input"/>


                </VBox>






                <Button text="LOGIN"
                        onAction="#login"
                        styleClass="login-button"/>





                <!-- SOCIALS -->

                <VBox alignment="CENTER"
                      spacing="12"
                      styleClass="social-area">


                    <Label text="Follow StockPilot"
                           styleClass="social-title"/>


                    <HBox spacing="20"
      alignment="CENTER">


    <ImageView fitWidth="28"
               fitHeight="28">

        <image>

            <Image url="@../icons/instagram.png"/>

        </image>

    </ImageView>



    <ImageView fitWidth="28"
               fitHeight="28">

        <image>

            <Image url="@../icons/facebook.png"/>

        </image>

    </ImageView>



    <ImageView fitWidth="28"
               fitHeight="28">

        <image>

            <Image url="@../icons/tiktok.png"/>

        </image>

    </ImageView>


</HBox>


                </VBox>




            </VBox>



        </HBox>



    </AnchorPane>


</StackPane>