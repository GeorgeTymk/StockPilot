<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.stockpilot.controller.LoginController"
            stylesheets="@../css/login.css">


    <center>

        <HBox alignment="CENTER"
              spacing="0"
              styleClass="login-container">


            <!-- LEFT BRAND PANEL -->

            <VBox alignment="CENTER"
                  spacing="15"
                  prefWidth="430"
                  styleClass="brand-panel">


                <Label text="STOCKPILOT"
                       styleClass="brand-title"/>


                <Label text="Smart Restaurant Inventory Management"
                       wrapText="true"
                       styleClass="brand-description"/>


                <Label text="Control stock. Track sales. Grow your business."
                       wrapText="true"
                       styleClass="brand-small"/>


                <HBox spacing="15"
                      alignment="CENTER"
                      styleClass="social-box">


                    <Label text="Instagram"
                           styleClass="social"/>

                    <Label text="Facebook"
                           styleClass="social"/>

                    <Label text="TikTok"
                           styleClass="social"/>


                </HBox>


            </VBox>



            <!-- LOGIN CARD -->


            <VBox spacing="18"
                  alignment="CENTER"
                  maxWidth="340"
                  styleClass="login-card">


                <padding>
                    <Insets top="35"
                            right="35"
                            bottom="35"
                            left="35"/>
                </padding>


                <Label text="Welcome Back"
                       styleClass="welcome"/>


                <Label text="Sign in to continue"
                       styleClass="subtitle"/>


                <TextField fx:id="usernameField"
                           promptText="Username"
                           styleClass="input"/>


                <PasswordField fx:id="passwordField"
                               promptText="Password"
                               styleClass="input"/>



                <Button text="Sign In"
                        onAction="#login"
                        maxWidth="Infinity"
                        styleClass="login-button"/>


            </VBox>


        </HBox>


    </center>



    <bottom>

        <VBox alignment="CENTER"
              spacing="3"
              styleClass="footer">

            <Label text="© 2026 StockPilot"
                   styleClass="footer-text"/>


            <Label text="Designed by George Tymk | Phoenix Systems"
                   styleClass="footer-small"/>


        </VBox>

    </bottom>


</BorderPane>