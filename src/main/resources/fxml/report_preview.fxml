<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>


<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.stockpilot.controller.ReportPreviewController"
           styleClass="preview-overlay">


    <!-- A4 PAPER -->

    <BorderPane prefWidth="595"
            prefHeight="842"
            minHeight="842"
            styleClass="paper-preview">


        <!-- HEADER -->

        <top>

            <HBox alignment="CENTER_RIGHT">

                <padding>

                    <Insets top="10"
                            right="10"
                            bottom="0"
                            left="10"/>

                </padding>


                <Button text="✕"
                        onAction="#closePreview"
                        styleClass="close-button"/>


            </HBox>


        </top>




        <!-- REPORT BODY -->

        <center>


            <ScrollPane fitToWidth="true"
            vbarPolicy="AS_NEEDED"
            hbarPolicy="NEVER"
            style="-fx-background-color:transparent;"
            pannable="true">


                <VBox spacing="20"
      minHeight="900"
      fillWidth="true"
      styleClass="report-content">


                    <padding>

                        <Insets top="25"
                                right="40"
                                bottom="40"
                                left="40"/>

                    </padding>



                    <!-- BRAND -->

                    <!-- REPORT HEADER -->

<VBox spacing="5"
      alignment="CENTER_LEFT">


    <Label text="STOCKPILOT"
           styleClass="report-title"/>


    <Label text="Restaurant Inventory Management System"
           styleClass="report-system"/>


    <Label text="Business Performance Report"
           styleClass="report-subtitle"/>


    <Label fx:id="dateLabel"
           styleClass="report-date"/>


</VBox>




                    <Separator/>




                    <!-- KPI CARDS -->

                    <GridPane fx:id="kpiGrid"
                              hgap="15"
                              vgap="15"/>





                    <Separator/>





                    <!-- REPORT CONTENT -->

                    <VBox fx:id="contentBox"
                          spacing="15"/>





                    <Separator/>





                    <!-- SALES CHART -->

                    <Label text="Sales Trend"
                           styleClass="report-section-title"/>



                    <StackPane fx:id="chartContainer"
                               prefHeight="260"/>




                    <Separator/>




                    <!-- FOOTER -->




                </VBox>


            </ScrollPane>


        </center>
<bottom>

    <VBox spacing="5"
          alignment="CENTER"
          styleClass="report-footer-box">


        <Label text="Generated by StockPilot Restaurant Inventory System"
               styleClass="report-footer"/>


        <Label text="Confidential Business Report"
               styleClass="report-footer-small"/>


    </VBox>

</bottom>

    </BorderPane>


</StackPane>