<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.stockpilot.controller.RecipeDetailsController"
      spacing="0">


    <!-- SHARED SIDEBAR -->

    <fx:include source="sidebar.fxml"/>



    <!-- PAGE CONTENT -->

    <BorderPane HBox.hgrow="ALWAYS"
                styleClass="page-container">



        <!-- HEADER -->

        <top>

            <HBox alignment="CENTER_LEFT"
                  styleClass="page-header">


                <padding>

                    <Insets top="20"
                            right="25"
                            bottom="20"
                            left="25"/>

                </padding>


                <VBox spacing="5">


                    <Label text="Recipe Details"
                           styleClass="page-title"/>


                    <Label text="View ingredients and recipe information"
                           styleClass="subtitle"/>


                </VBox>


            </HBox>


        </top>






        <!-- CENTER -->

        <center>


            <VBox spacing="20"
                  fillWidth="true">


                <padding>

                    <Insets top="25"
                            right="25"
                            bottom="25"
                            left="25"/>

                </padding>






                <!-- RECIPE INFORMATION -->


                <HBox spacing="60">



                    <VBox spacing="5">


                        <Label text="Recipe Name"/>


                        <Label fx:id="recipeNameLabel"
                               text="-"
                               styleClass="subtitle"/>


                    </VBox>





                    <VBox spacing="5">


                        <Label text="Selling Price"/>


                        <Label fx:id="sellingPriceLabel"
                               text="0"
                               styleClass="subtitle"/>


                    </VBox>



                </HBox>






                <Separator/>






                <Label text="Ingredients Used"
                       styleClass="title"/>






                <TableView fx:id="ingredientTable"
                           VBox.vgrow="ALWAYS">


                    <columns>


                        <TableColumn fx:id="nameColumn"
                                     text="Ingredient"
                                     prefWidth="250"/>



                        <TableColumn fx:id="quantityColumn"
                                     text="Quantity"
                                     prefWidth="150"/>



                        <TableColumn fx:id="unitColumn"
                                     text="Unit"
                                     prefWidth="150"/>



                    </columns>


                </Table>








                <!-- BUTTONS -->


                <HBox spacing="15"
                      alignment="CENTER_LEFT">



                    <Button text="Add Ingredient"
                            onAction="#addIngredient"
                            styleClass="primary-button"/>



                    <Button text="Remove Ingredient"
                            onAction="#removeIngredient"
                            styleClass="secondary-button"/>



                    <Button text="Back"
                            onAction="#goBack"
                            styleClass="secondary-button"/>



                </HBox>




            </VBox>



        </center>



    </BorderPane>



</HBox>