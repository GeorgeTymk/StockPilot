<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.stockpilot.controller.RecipeDetailsController">


    <top>

        <VBox spacing="10">

            <padding>
                <Insets top="25"
                        right="30"
                        bottom="20"
                        left="30"/>
            </padding>


            <Label text="Recipe Details"
                   styleClass="title"/>


        </VBox>

    </top>




    <center>


        <VBox spacing="20">


            <padding>
                <Insets top="20"
                        right="30"
                        bottom="20"
                        left="30"/>
            </padding>



            <HBox spacing="40">


                <VBox spacing="5">

                    <Label text="Recipe Name"/>

                    <Label fx:id="recipeNameLabel"
                           text="-"
                           styleClass="subtitle"/>

                </VBox>




                <VBox spacing="5">

                    <Label text="Selling Price"/>

                    <Label fx:id="sellingPriceLabel"
                           text="0"
                           styleClass="subtitle"/>

                </VBox>



            </HBox>




            <Separator/>




            <Label text="Ingredients Used"
                   styleClass="subtitle"/>




            <TableView fx:id="ingredientTable"
                       prefHeight="350">


                <columns>


                    <TableColumn fx:id="nameColumn"
                                 text="Ingredient"
                                 prefWidth="250"/>



                    <TableColumn fx:id="quantityColumn"
                                 text="Quantity"
                                 prefWidth="150"/>



                    <TableColumn fx:id="unitColumn"
                                 text="Unit"
                                 prefWidth="150"/>



                </columns>


            </TableView>




            <HBox spacing="15">


                <Button text="Add Ingredient"
                        onAction="#addIngredient"/>



                <Button text="Remove Ingredient"
                        onAction="#removeIngredient"/>

                <Button text="Back"
        onAction="#goBack"/>


            </HBox>




        </VBox>


    </center>


</BorderPane>