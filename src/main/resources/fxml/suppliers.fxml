<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.stockpilot.controller.SupplierController">


    <top>

        <HBox style="-fx-background-color:#1e293b;">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>


            <Label text="Supplier Management"
                   style="-fx-text-fill:white;
                          -fx-font-size:22px;"/>

        </HBox>

    </top>



    <center>


        <VBox spacing="20">


            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>



            <TableView fx:id="supplierTable">


                <columns>


                    <TableColumn fx:id="idColumn"
                                 text="ID"/>


                    <TableColumn fx:id="nameColumn"
                                 text="Supplier Name"/>


                    <TableColumn fx:id="phoneColumn"
                                 text="Phone"/>


                    <TableColumn fx:id="emailColumn"
                                 text="Email"/>


                </columns>


            </TableView>



            <Button text="Add Supplier"
                    onAction="#addSupplier"/>

                    <Button text="Back"
        onAction="#goBack"/>


        </VBox>


    </center>


</BorderPane>