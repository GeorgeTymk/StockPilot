<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>


<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.stockpilot.controller.AddIngredientController">


    <center>

        <VBox spacing="20"
              alignment="CENTER">


            <padding>
                <Insets top="40"
                        right="40"
                        bottom="40"
                        left="40"/>
            </padding>



            <Label text="Add Ingredient"
                   style="-fx-font-size:25px;
                          -fx-font-weight:bold;"/>



            <TextField fx:id="nameField"
                       promptText="Ingredient Name"/>



            <TextField fx:id="quantityField"
                       promptText="Quantity"/>



            <TextField fx:id="unitField"
                       promptText="Unit (kg, pcs, litres)"/>

            <TextField fx:id="minimumStockField"
           promptText="Minimum Stock"/>



            <Button text="Save Ingredient"
                    onAction="#saveIngredient"/>

            <Button text="Back"
        onAction="#goBack"/>


        </VBox>


    </center>


</BorderPane>