<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.stockpilot.controller.LowStockController"
      spacing="0">


    <!-- SHARED SIDEBAR -->






    <!-- PAGE CONTENT -->

    <BorderPane HBox.hgrow="ALWAYS"
                styleClass="page-container">



        <!-- HEADER -->

        <top>


            <HBox alignment="CENTER_LEFT"
                  styleClass="page-header">


                <padding>

                    <Insets top="20"
                            right="25"
                            bottom="20"
                            left="25"/>

                </padding>



                <VBox spacing="5">


                    <Label text="Low Stock Warning"
                           styleClass="page-title"/>


                    <Label text="Ingredients requiring attention"
                           styleClass="subtitle"/>


                </VBox>



            </HBox>


        </top>






        <!-- CONTENT -->

        <center>


            <VBox spacing="20">


                <padding>

                    <Insets top="25"
                            right="25"
                            bottom="25"
                            left="25"/>

                </padding>





                <TableView fx:id="lowStockTable"
                           VBox.vgrow="ALWAYS">



                    <columns>



                        <TableColumn fx:id="nameColumn"
                                     text="Ingredient"
                                     prefWidth="250"/>



                        <TableColumn fx:id="quantityColumn"
                                     text="Current Quantity"
                                     prefWidth="180"/>



                        <TableColumn fx:id="minimumColumn"
                                     text="Minimum Stock"
                                     prefWidth="180"/>



                        <TableColumn fx:id="unitColumn"
                                     text="Unit"
                                     prefWidth="120"/>



                    </columns>



                </TableView>






                <HBox spacing="15"
                      alignment="CENTER_LEFT">


                    <Button text="Refresh"
                            onAction="#refresh"
                            styleClass="primary-button"/>



                    <Button text="Back"
                            onAction="#goBack"
                            styleClass="secondary-button"/>


                </HBox>





            </VBox>



        </center>





    </BorderPane>



</HBox>