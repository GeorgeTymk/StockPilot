<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>


<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.stockpilot.controller.MainShellController"
            styleClass="dashboard-background">


    <center>

        <HBox spacing="12"
              styleClass="app-frame">


            <padding>
                <Insets top="20"
                        right="20"
                        bottom="20"
                        left="20"/>
            </padding>



            <!-- ONLY SIDEBAR -->

            <fx:include source="sidebar.fxml"/>



            <!-- WHITE CONTENT CARD -->

            <StackPane fx:id="contentArea"
                       HBox.hgrow="ALWAYS"
                       styleClass="floating-dashboard"/>



        </HBox>


    </center>


</BorderPane>