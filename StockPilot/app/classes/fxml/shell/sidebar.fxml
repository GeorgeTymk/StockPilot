<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.stockpilot.controller.SidebarController"
      styleClass="modern-sidebar"
      prefWidth="210"
      minWidth="210"
      maxWidth="210"
      prefHeight="650"
      maxHeight="650">

    <padding>
        <Insets top="30"
                right="18"
                bottom="30"
                left="18"/>
    </padding>

    <!-- ================================================= -->
    <!-- BRAND -->
    <!-- ================================================= -->

    <VBox spacing="5">

        <Label text="StockPilot"
               styleClass="brand-title"/>

        <Label text="Restaurant OS"
               styleClass="brand-subtitle"/>

    </VBox>

    <Separator/>

    <Region prefHeight="10"/>

    <!-- ================================================= -->
    <!-- NAVIGATION -->
    <!-- ================================================= -->

    <VBox spacing="8">

        <!-- DASHBOARD -->

        <VBox fx:id="dashboardNav"
      styleClass="nav-item">

            <Button fx:id="dashboardBtn"
                    text="Dashboard"
                    styleClass="modern-sidebar-button"
                    onAction="#openDashboard">

                <graphic>
                    <ImageView fitWidth="20"
                               fitHeight="20">
                        <image>
                            <Image url="@../../icons/dashboard.png"/>
                        </image>
                    </ImageView>
                </graphic>

            </Button>

        </VBox>

        <!-- INVENTORY -->

        <VBox fx:id="inventoryNav"
              styleClass="nav-item">

            <Button fx:id="inventoryBtn"
                    text="Inventory"
                    styleClass="modern-sidebar-button"
                    onAction="#openInventory">

                <graphic>
                    <ImageView fitWidth="20"
                               fitHeight="20">
                        <image>
                            <Image url="@../../icons/inventory.png"/>
                        </image>
                    </ImageView>
                </graphic>

            </Button>

        </VBox>

        <!-- INGREDIENTS -->

        <VBox fx:id="ingredientsNav"
              styleClass="nav-item">

            <Button fx:id="ingredientsBtn"
                    text="Ingredients"
                    styleClass="modern-sidebar-button"
                    onAction="#openIngredients">

                <graphic>
                    <ImageView fitWidth="20"
                               fitHeight="20">
                        <image>
                            <Image url="@../../icons/ingredients.png"/>
                        </image>
                    </ImageView>
                </graphic>

            </Button>

        </VBox>

        <!-- RECIPES -->

        <VBox fx:id="recipesNav"
              styleClass="nav-item">

            <Button fx:id="recipesBtn"
                    text="Recipes"
                    styleClass="modern-sidebar-button"
                    onAction="#openRecipes">

                <graphic>
                    <ImageView fitWidth="20"
                               fitHeight="20">
                        <image>
                            <Image url="@../../icons/recipes.png"/>
                        </image>
                    </ImageView>
                </graphic>

            </Button>

        </VBox>

        <!-- SUPPLIERS -->

        <VBox fx:id="suppliersNav"
              styleClass="nav-item">

            <Button fx:id="suppliersBtn"
                    text="Suppliers"
                    styleClass="modern-sidebar-button"
                    onAction="#openSuppliers">

                <graphic>
                    <ImageView fitWidth="20"
                               fitHeight="20">
                        <image>
                            <Image url="@../../icons/suppliers.png"/>
                        </image>
                    </ImageView>
                </graphic>

            </Button>

        </VBox>

        <!-- SALES -->

        <VBox fx:id="salesNav"
              styleClass="nav-item">

            <Button fx:id="salesBtn"
                    text="Sales"
                    styleClass="modern-sidebar-button"
                    onAction="#openSales">

                <graphic>
                    <ImageView fitWidth="20"
                               fitHeight="20">
                        <image>
                            <Image url="@../../icons/sales.png"/>
                        </image>
                    </ImageView>
                </graphic>

            </Button>

        </VBox>

        <!-- SALES HISTORY -->

        <VBox fx:id="salesHistoryNav"
              styleClass="nav-item">

            <Button fx:id="salesHistoryBtn"
                    text="Sales History"
                    styleClass="modern-sidebar-button"
                    onAction="#openSalesHistory">

                <graphic>
                    <ImageView fitWidth="20"
                               fitHeight="20">
                        <image>
                            <Image url="@../../icons/history.png"/>
                        </image>
                    </ImageView>
                </graphic>

            </Button>

        </VBox>

        <!-- REPORTS -->

        <VBox fx:id="reportsNav"
              styleClass="nav-item">

            <Button fx:id="reportsBtn"
                    text="Reports"
                    styleClass="modern-sidebar-button"
                    onAction="#openReports">

                <graphic>
                    <ImageView fitWidth="20"
                               fitHeight="20">
                        <image>
                            <Image url="@../../icons/reports.png"/>
                        </image>
                    </ImageView>
                </graphic>

            </Button>

        </VBox>

        <!-- LOW STOCK -->

        <VBox fx:id="lowStockNav"
              styleClass="nav-item">

            <Button fx:id="lowStockBtn"
                    text="Low Stock"
                    styleClass="modern-sidebar-button"
                    onAction="#openLowStock">

                <graphic>
                    <ImageView fitWidth="20"
                               fitHeight="20">
                        <image>
                            <Image url="@../../icons/warning.png"/>
                        </image>
                    </ImageView>
                </graphic>

            </Button>

        </VBox>

    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- ================================================= -->
    <!-- PROFILE -->
    <!-- ================================================= -->

    <VBox spacing="3"
          styleClass="profile-box">

        <Label text="Admin"
               styleClass="profile-name"/>

        <Label text="Administrator"
               styleClass="profile-role"/>

    </VBox>

    <!-- ================================================= -->
    <!-- LOGOUT -->
    <!-- ================================================= -->

    <VBox styleClass="nav-item">

        <Button text="Logout"
                styleClass="modern-sidebar-button"
                onAction="#logout">

            <graphic>
                <ImageView fitWidth="20"
                           fitHeight="20">
                    <image>
                        <Image url="@../../icons/logout.png"/>
                    </image>
                </ImageView>
            </graphic>

        </Button>

    </VBox>

</VBox>