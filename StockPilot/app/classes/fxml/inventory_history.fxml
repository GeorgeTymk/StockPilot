<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.stockpilot.controller.InventoryHistoryController">


    <!-- HEADER -->

    <top>

        <HBox spacing="20"
              alignment="CENTER_LEFT"
              style="-fx-background-color:#1e293b;">

            <padding>
                <Insets top="20"
                        right="20"
                        bottom="20"
                        left="20"/>
            </padding>


            <Label text="Inventory History"
                   style="
                   -fx-text-fill:white;
                   -fx-font-size:22px;
                   -fx-font-weight:bold;
                   "/>


        </HBox>

    </top>



    <!-- CONTENT -->

    <center>


        <VBox spacing="20">


            <padding>

                <Insets top="20"
                        right="20"
                        bottom="20"
                        left="20"/>

            </padding>



            <TableView fx:id="historyTable"
                       prefHeight="450"
                       prefWidth="900">



                <columns>



                    <TableColumn fx:id="idColumn"
                                 text="ID"
                                 prefWidth="80"/>




                    <TableColumn fx:id="ingredientColumn"
                                 text="Ingredient"
                                 prefWidth="200"/>




                    <TableColumn fx:id="movementColumn"
                                 text="Movement"
                                 prefWidth="150"/>




                    <TableColumn fx:id="quantityColumn"
                                 text="Quantity"
                                 prefWidth="120"/>




                    <TableColumn fx:id="dateColumn"
                                 text="Date"
                                 prefWidth="250"/>



                </columns>



            </TableView>





            <HBox spacing="15">


                <Button text="Back"
                        onAction="#goBack"
                        prefWidth="100"/>


            </HBox>



        </VBox>



    </center>



</BorderPane>