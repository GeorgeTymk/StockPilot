<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.stockpilot.controller.ReportsController"
      spacing="0">


    <!-- SIDEBAR -->






    <!-- PAGE CONTENT -->

    <BorderPane HBox.hgrow="ALWAYS"
                styleClass="page-container">



        <!-- HEADER -->

        <top>


            <HBox alignment="CENTER_LEFT"
                  styleClass="page-header">


                <padding>

                    <Insets top="20"
                            right="25"
                            bottom="20"
                            left="25"/>

                </padding>



                <VBox spacing="5">


                    <Label text="Sales Reports"
                           styleClass="page-title"/>


                    <Label text="Business performance overview"
                           styleClass="subtitle"/>


                </VBox>



            </HBox>


        </top>






        <!-- CONTENT -->

        <center>

    <VBox spacing="25"
          styleClass="floating-dashboard">

        <padding>
            <Insets top="30"
                    right="35"
                    bottom="30"
                    left="35"/>
        </padding>

        <!-- REPORT OPTIONS -->

        <VBox spacing="15"
              styleClass="dashboard-stat-card">

            <Label text="Generate Report"
                   styleClass="section-title"/>

            <Label text="Choose what should be included in the report."
                   styleClass="trend-text"/>

            <GridPane hgap="40"
                      vgap="15">

                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <CheckBox fx:id="salesSummaryCheck"
                          text="Sales Summary"
                          GridPane.columnIndex="0"
                          GridPane.rowIndex="0"/>

                <CheckBox fx:id="todaySalesCheck"
                          text="Today's Sales"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="0"/>

                <CheckBox fx:id="inventoryCheck"
                          text="Inventory Status"
                          GridPane.columnIndex="0"
                          GridPane.rowIndex="1"/>

                <CheckBox fx:id="lowStockCheck"
                          text="Low Stock Items"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="1"/>

                <CheckBox fx:id="outOfStockCheck"
                          text="Out Of Stock Items"
                          GridPane.columnIndex="0"
                          GridPane.rowIndex="2"/>

                <CheckBox fx:id="recipeCheck"
                          text="Recipe Performance"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="2"/>

                <CheckBox fx:id="activityCheck"
                          text="Recent Activity"
                          GridPane.columnIndex="0"
                          GridPane.rowIndex="3"/>

                <CheckBox fx:id="bestSellerCheck"
                          text="Best Selling Recipe"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="3"/>

            </GridPane>

        </VBox>



        <!-- PREVIEW -->

        <VBox spacing="15"
              VBox.vgrow="ALWAYS"
              styleClass="chart-card">

            <Label text="Report Preview"
                   styleClass="section-title"/>

            <TextArea fx:id="previewArea"
                      editable="false"
                      wrapText="true"
                      prefHeight="320"
                      promptText="The report preview will appear here..."/>

        </VBox>



        <!-- ACTION BUTTONS -->

        <HBox spacing="15">

            <Button text="Generate Preview"
                    onAction="#generatePreview"
                    styleClass="green-action-button"/>

            <Button text="Export PDF"
                    onAction="#exportPDF"
                    styleClass="green-action-button"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Back"
                    onAction="#goBack"
                    styleClass="secondary-button"/>

        </HBox>

    </VBox>

</center>




    </BorderPane>



</HBox>